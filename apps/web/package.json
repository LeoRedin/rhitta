{
  "name": "@rhitta/web",
  "version": "0.0.0",
  "private": true,
  "description": "Rhitta web app — TanStack Start SSR client consuming the @rhitta/api Encore service.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "node ./.output/server/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "pnpm typecheck && pnpm test",
    "gen:api-client": "bash ./scripts/gen-api-client.sh"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-toast": "1.2.15",
    "@rhitta/contracts": "workspace:*",
    "@rhitta/design-system-web": "workspace:*",
    "@rhitta/design-tokens": "workspace:*",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/react-form": "1.32.1",
    "@tanstack/react-query": "5.100.14",
    "@tanstack/react-router": "1.170.8",
    "@tanstack/react-start": "1.168.14",
    "better-auth": "1.6.11",
    "class-variance-authority": "0.7.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwindcss": "4.3.0",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@rhitta/biome-config": "workspace:*",
    "@rhitta/tsconfig": "workspace:*",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "22.19.19",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "jsdom": "29.1.1",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vitest": "4.1.7"
  }
}
