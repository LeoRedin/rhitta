{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@rhitta/tsconfig/api-app.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "paths": {
      "~encore/*": ["./encore.gen/*"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "encore.gen"]
}
