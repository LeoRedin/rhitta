# --- Required ---------------------------------------------------------------
# Postgres connection string. In dev, Encore provisions a local Postgres and
# overrides this — set it explicitly only for production deploys.
DATABASE_URL=postgres://user:pass@host:5432/rhitta
# Better Auth signing secret. Generate with `openssl rand -base64 32`.
BETTER_AUTH_SECRET=replace-me-with-a-long-random-string
# Public base URL of the API. Better Auth uses this to build callback URLs.
BETTER_AUTH_URL=http://localhost:4000

# --- Optional (in-memory fallback) ------------------------------------------
# When missing, composeRoot wires an in-memory adapter instead. Fine for
# local dev; mandatory for production.
ANTHROPIC_API_KEY=sk-ant-...
RESEND_API_KEY=re_...

# --- Optional S3-compatible storage -----------------------------------------
# All five S3_ vars are required *together*. Missing any one of them falls
# back to the in-memory storage adapter. Defaults target Cloudflare R2.
S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=...
S3_SECRET_ACCESS_KEY=...
S3_BUCKET=rhitta
