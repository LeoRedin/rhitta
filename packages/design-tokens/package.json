{
  "name": "@rhitta/design-tokens",
  "version": "0.0.0",
  "private": false,
  "description": "Two-layer (primitive + semantic) design tokens with dual themes (light + dark) for Rhitta web and mobile consumers.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./primitive": {
      "types": "./dist/src/primitive.d.ts",
      "default": "./dist/src/primitive.js"
    },
    "./semantic": {
      "types": "./dist/src/semantic.d.ts",
      "default": "./dist/src/semantic.js"
    },
    "./css": "./dist/tokens.css",
    "./tailwind": "./dist/theme.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.build.json && node ./dist/scripts/build-css.js",
    "validate": "pnpm typecheck && pnpm build",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@rhitta/biome-config": "workspace:*",
    "@rhitta/tsconfig": "workspace:*",
    "@types/node": "22.19.19",
    "typescript": "6.0.3"
  }
}
