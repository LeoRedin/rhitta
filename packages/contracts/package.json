{
  "name": "@rhitta/contracts",
  "version": "0.0.0",
  "private": false,
  "description": "Single source of truth for cross-boundary wire schemas (Zod) in Rhitta — Phase 1 ships shared primitives only.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/src/shared/index.js",
  "types": "./dist/src/shared/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    "./shared": {
      "types": "./dist/src/shared/index.d.ts",
      "default": "./dist/src/shared/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "validate": "pnpm typecheck && pnpm build",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@rhitta/biome-config": "workspace:*",
    "@rhitta/tsconfig": "workspace:*",
    "typescript": "6.0.3"
  }
}
