{
	"name": "@rhitta/design-system-web",
	"version": "0.0.0",
	"private": false,
	"description": "Rhitta web design system primitives. Empty in Phase 1; Phase 2b populates.",
	"license": "MIT",
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"main": "./dist/src/index.js",
	"types": "./dist/src/index.d.ts",
	"files": [
		"dist",
		"src"
	],
	"exports": {
		".": {
			"types": "./dist/src/index.d.ts",
			"default": "./dist/src/index.js"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"build": "tsc -p tsconfig.build.json",
		"validate": "pnpm typecheck && pnpm build",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@rhitta/design-tokens": "workspace:*"
	},
	"devDependencies": {
		"@rhitta/biome-config": "workspace:*",
		"@rhitta/tsconfig": "workspace:*",
		"typescript": "6.0.3"
	}
}
